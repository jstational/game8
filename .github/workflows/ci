name: CI

on:
  push:
    branches: ["main"]
  release: {}

jobs:
  build:
    name: "build"
    runs-on: windows-latest
    
    steps:
      - uses: actions/checkout@v4

      - name: jdk25
        uses: actions/setup-java@v4
        with:
          java-version: '25'
          distribution: 'temurin'
          cache: gradle
      
      - name: buildgradle
        run: .\gradlew build

      - name: upload
        uses: actions/upload-artifact@v4
        with: 
          name: "game8"
          path: build/libs/*.jar
  
